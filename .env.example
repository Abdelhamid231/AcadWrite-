# Copy this file to .env for local development, and set the same keys as
# Environment Variables in your Vercel project settings for production.

PORT=3000

# Supabase project (Auth + Storage + Postgres). Create a project at
# supabase.com, then find these under Project Settings:
# - SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY: Settings > API
#   (use the "service_role" secret key, NOT the "anon" public key)
# - POSTGRES_URL: Settings > Database > Connection string (URI, "Transaction"
#   pooler mode is recommended since this runs in serverless functions)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL=

# Random long string used to sign our own login session cookie (separate
# from Supabase's own tokens). Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

ADMIN_EMAIL=admin@acadwrite.local
ADMIN_PASSWORD=Admin123!
