# Copy this file to .env for local development, and set the same keys as
# Environment Variables in your Vercel project settings for production.

PORT=3000

# Postgres connection string. On Vercel: add the "Postgres" (Neon) storage
# integration to your project and it injects POSTGRES_URL automatically.
# For local dev, paste the same connection string here.
POSTGRES_URL=

# Vercel Blob (file storage). Add the "Blob" storage integration to your
# Vercel project and it injects BLOB_READ_WRITE_TOKEN automatically.
# For local dev, copy the token from the Vercel dashboard (Storage > your
# Blob store > .env.local tab).
BLOB_READ_WRITE_TOKEN=

# Random long string used to sign login sessions (JWT). Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

ADMIN_EMAIL=admin@acadwrite.local
ADMIN_PASSWORD=Admin123!
